@startuml
skinparam backgroundColor #F8F9FA
skinparam activityBackgroundColor #E8F5E9
skinparam activityBorderColor #388E3C
skinparam activityStartColor #4CAF50
skinparam activityEndColor #F44336
skinparam activityDiamondBackgroundColor #FFF3E0

title Activity Diagram: Add Employee

start
:Click "ADD EMPLOYEE";
:Open add dialog;

repeat
    :Enter full name;
    :Enter position;
    :Load photo;
repeat while (Data entered)

:Click "SAVE";
:FaceService.encode_face(photo);

if (Face detected) then (yes)
    :Save photo to photos/;
    :Database.add_employee();
    
    :Update ID in filename;
    :Save photo path;
    
    :MainWindow._on_employee_added();
    :event_log.log("Employee added...");
    
    note right: Success
else (no)
    :event_log.log("Failed\nto detect face");
    
    note right: Error
endif

:Close dialog;

stop

@enduml
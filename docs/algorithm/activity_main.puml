@startuml
skinparam backgroundColor #F8F9FA
skinparam activityBackgroundColor #E3F2FD
skinparam activityBorderColor #1976D2
skinparam activityStartColor #4CAF50
skinparam activityEndColor #F44336
skinparam activityDiamondBackgroundColor #FFF3E0
skinparam activityDiamondBorderColor #FF9800

title Activity Diagram: Main Application Flow

start
:App Launch;
:Database Init (Database);
:Services Init (DataStore, FaceService, KeyService, CameraService);
:UI Creation (MainWindow);

fork
    :Video Stream Start;
    repeat
        :Get frame from camera;
        :Display video in UI;
    repeat while (App is open)
fork again
    :Wait for user actions;
    repeat
        :Select action;
    repeat while (App is open)
end merge

:App Close;
:Camera resources release;
:DB connection close;

stop

@enduml